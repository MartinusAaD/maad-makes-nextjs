rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ─── Users ──────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ─── Products ───────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Categories ─────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Filaments ──────────────────────────────────────────────────
    match /filaments/{filamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Images ─────────────────────────────────────────────────────
    match /images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Orders ─────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Anyone (even unauthenticated) can create an order
      allow create: if true;

      // Signed-in users can read their own orders
      allow read: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || isAdmin());

      // Only admin can update or delete
      allow update, delete: if isAdmin();
    }

    // ─── Metadata ───────────────────────────────────────────────────
    match /metadata/{docId} {
      allow read: if true;
      allow write: if docId == "orderCounter" || docId == "customerCounter";
    }
  }
}
